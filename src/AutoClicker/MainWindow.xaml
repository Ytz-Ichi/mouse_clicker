<Window x:Class="AutoClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AutoClicker.Converters"
        Title="Auto Clicker (Safe)"
        MinWidth="520" MinHeight="520"
        Width="540" Height="620"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>

    <DockPanel>
        <!-- 1) ステータスバー（上部） -->
        <StatusBar DockPanel.Dock="Top">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="状態: "/><Run Text="{Binding StatusText, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="モード: "/><Run Text="{Binding ModeText, Mode=OneWay}"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- 7) 操作ボタン + 8) 常駐（最下部） -->
        <StackPanel DockPanel.Dock="Bottom" Margin="8">
            <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,6">
                <Button Content="開始" Width="80" Margin="4"
                        Command="{Binding StartCommand}"/>
                <Button Content="停止" Width="80" Margin="4"
                        Command="{Binding StopCommand}"/>
                <Button Content="終了" Width="80" Margin="4"
                        Command="{Binding ExitCommand}"/>
            </WrapPanel>
            <CheckBox Content="タスクトレイに常駐する"
                      IsChecked="{Binding IsResidentTray}"
                      HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- エラーメッセージ -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red" Margin="8,2"
                   TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                   x:Name="ErrorText"/>

        <!-- 中央コンテンツ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
            <StackPanel Margin="4">

                <!-- 2) モード選択 -->
                <GroupBox Header="モード選択" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal" Margin="8,4">
                        <RadioButton Content="単一点" GroupName="Mode"
                                     IsChecked="{Binding IsSingleMode}" Margin="0,0,16,0"/>
                        <RadioButton Content="複数点" GroupName="Mode"
                                     IsChecked="{Binding IsMultiMode}"/>
                    </StackPanel>
                </GroupBox>

                <!-- 3) 共通設定 -->
                <GroupBox Header="共通設定" Margin="0,0,0,6">
                    <Grid Margin="8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- クリック種別 -->
                        <TextBlock Text="クリック種別" Grid.Row="0" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"
                                  SelectedIndex="{Binding ClickTypeIndex}">
                            <ComboBoxItem Content="左クリック"/>
                            <ComboBoxItem Content="右クリック"/>
                            <ComboBoxItem Content="中クリック"/>
                        </ComboBox>

                        <!-- 間隔(ms) -->
                        <TextBlock Text="間隔(ms)" Grid.Row="1" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,6"
                                 Text="{Binding IntervalMs, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- 回数 -->
                        <TextBlock Text="回数" Grid.Row="2" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <RadioButton Content="無限" GroupName="Count"
                                         IsChecked="{Binding IsInfinite}"
                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <RadioButton Content="指定回数" GroupName="Count"
                                         IsChecked="{Binding IsFixedCount}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox Width="100"
                                     Text="{Binding FixedCount, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsFixedCount}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- 4) 単一点モード設定 -->
                <GroupBox Header="単一点設定"
                          Visibility="{Binding IsSingleMode, Converter={StaticResource BoolToVis}}"
                          Margin="0,0,0,6">
                    <StackPanel Margin="8,4">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="X:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Width="80" Margin="0,0,16,0"
                                     Text="{Binding SingleX, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Y:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Width="80"
                                     Text="{Binding SingleY, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <WrapPanel Margin="0,0,0,6">
                            <Button Content="現在位置を取得" Margin="0,0,8,0"
                                    Command="{Binding GetPositionNowCommand}"/>
                            <Button Content="3秒後に取得" Margin="0,0,0,0"
                                    Command="{Binding GetPosition3sCommand}"/>
                        </WrapPanel>
                        <TextBlock Text="※ マルチモニタ環境では座標が負になる場合があります。"
                                   FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>

                <!-- 5) 複数点モード設定 -->
                <GroupBox Header="複数点設定"
                          Visibility="{Binding IsMultiMode, Converter={StaticResource BoolToVis}}"
                          Margin="0,0,0,6">
                    <StackPanel Margin="8,4">
                        <DataGrid ItemsSource="{Binding MultiPoints}"
                                  SelectedIndex="{Binding SelectedPointIndex}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  HeadersVisibility="Column"
                                  MinHeight="100" MaxHeight="200"
                                  Margin="0,0,0,6">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="#" Width="40" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                       Path=(ItemsControl.AlternationIndex),
                                                       StringFormat={}{0}}"
                                                       Margin="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="X" Binding="{Binding X}" Width="70"/>
                                <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="70"/>
                                <DataGridTextColumn Header="待機(ms)" Binding="{Binding ExtraWaitMs}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <WrapPanel>
                            <Button Content="追加(現在位置)" Margin="0,0,4,4"
                                    Command="{Binding AddPointNowCommand}"/>
                            <Button Content="追加(3秒後)" Margin="0,0,4,4"
                                    Command="{Binding AddPoint3sCommand}"/>
                            <Button Content="削除" Margin="0,0,4,4"
                                    Command="{Binding DeletePointCommand}"/>
                            <Button Content="上へ" Margin="0,0,4,4"
                                    Command="{Binding MovePointUpCommand}"/>
                            <Button Content="下へ" Margin="0,0,0,4"
                                    Command="{Binding MovePointDownCommand}"/>
                        </WrapPanel>
                        <TextBlock Text="※ マルチモニタ環境では座標が負になる場合があります。"
                                   FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>

                <!-- 6) ホットキー設定 -->
                <GroupBox Header="ホットキー" Margin="0,0,0,6">
                    <Grid Margin="8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="開始/停止:" Grid.Row="0" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,0,8,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   VerticalAlignment="Center" Margin="0,0,8,6">
                            <Run Text="{Binding ToggleHotkeyText, Mode=OneWay}"/>
                        </TextBlock>
                        <Button Content="変更" Grid.Row="0" Grid.Column="2"
                                Width="50" Margin="0,0,0,6"
                                Command="{Binding ChangeToggleHotkeyCommand}"/>

                        <TextBlock Text="停止:" Grid.Row="1" Grid.Column="0"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   VerticalAlignment="Center" Margin="0,0,8,0">
                            <Run Text="{Binding StopHotkeyText, Mode=OneWay}"/>
                        </TextBlock>
                        <Button Content="変更" Grid.Row="1" Grid.Column="2"
                                Width="50"
                                Command="{Binding ChangeStopHotkeyCommand}"/>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
